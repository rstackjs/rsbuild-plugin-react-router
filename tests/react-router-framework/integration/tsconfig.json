{
  "extends": "../tsconfig.base.json",
  "include": ["**/*.ts"],
  "exclude": [
    ".tmp/**",
    "helpers/rsbuild-template/**",
    "helpers/rsc-framework/**",
    "helpers/rsc-preview/**",
    "test-results/**"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": "."
  }
}
