{
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "build/**/*.ts",
    "react-router.config.ts",
    "rsbuild.config.ts",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022", "WebWorker"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "rootDirs": [".", "./.react-router/types"]
  }
}
